# Copy this file to .env and fill in your values
OPENAI_API_KEY=sk-...
N8N_ENCRYPTION_KEY=replace-with-a-random-32-char-string

# Denodo MCP server — already running, no changes needed
# From inside the Docker container, host machine is reached via host.docker.internal
DENODO_MCP_URL=http://host.docker.internal:8080/verticals/mcp
# Denodo credentials — used to create the HTTP Header Auth credential in n8n
DENODO_USER=admin
DENODO_PASSWORD=admin
